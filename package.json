{
  "name": "onefocus",
  "version": "1.0.0",
  "description": "OneFocus - Productivity app based on The One Thing methodology",
  "main": "server/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"node --watch server/index.js\" \"npm run dev --prefix client\"",
    "start": "node server/index.js",
    "db:init": "node server/db/init.js",
    "build": "npm run build --prefix client",
    "test": "node --test server/tests/*.test.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.3.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
