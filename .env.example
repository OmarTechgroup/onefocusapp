# Server
PORT=3900
DB_PATH=./data/onefocus.db

# Firebase Admin (server-side push). Get these from Firebase Console >
# Project Settings > Service Accounts > Generate new private key.
# Put the downloaded JSON file at server/fcm/serviceAccountKey.json
# (never commit it) OR set FIREBASE_SERVICE_ACCOUNT_JSON below as a
# one-line JSON string (useful for hosting providers without file uploads).
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase client config (public, used by client/src/firebase.js).
# From Firebase Console > Project Settings > General > Your apps > Web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
